<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/progress_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/progress_widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEMENTO MORI"
        android:textAllCaps="true"
        android:textColor="#E5E7EB"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/progress_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Vida completada"
        android:textColor="#CBD5E1"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progress_widget_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:layout_marginTop="14dp"
        android:max="10000"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_bar" />

    <TextView
        android:id="@+id/progress_widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="0.00% vivido"
        android:textColor="#A78BFA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/progress_widget_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Aún estás aquí."
        android:textColor="#A78BFA"
        android:textSize="14sp"
        android:textStyle="italic" />

</LinearLayout>